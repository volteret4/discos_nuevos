# Edita este archivo y guardalo en la raiz del proyecto, desde donde lanzarás los comandos, como .env

# Muspy
ATOM_FEED_URL=https://muspy.com/feed?id=1234567890
MUSPY_USERNAME=your_muspy_username
MUSPY_PASSWORD=your_muspy_password
MUSPY_USER_ID=1234567890

# CalDAV
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
CALENDAR_NAME=

# ICS
ICS_OUTPUT_FILENAME=music_releases.ics

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8080/callback

# Google
GOOGLE_CALENDAR_ID=your_email@gmail.com # Google Calendar ID (usually your email or a specific calendar ID)
GOOGLE_AUTH_METHOD=oauth # Authentication method: 'oauth' or 'service_account'
GOOGLE_SERVICE_ACCOUNT_FILE=path/to/service-account-key.json # For Service Account authentication (recommended for automation)
GOOGLE_OAUTH_CREDENTIALS_FILE=path/to/credentials.json # For OAuth2 authentication (interactive)

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
